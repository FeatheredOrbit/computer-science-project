{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "computer-science-project",
  "version": "0.1.0",
  "identifier": "com.chickenultra.computer-science-project",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Moonlight Theatre Management System",
        "width": 800,
        "height": 640,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/logo.png"
    ]
  }
}
